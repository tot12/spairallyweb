{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/auth/:path*",    "destination": "https://nchisecapi-production.up.railway.app/auth/:path*" },
    { "source": "/bella/:path*",   "destination": "https://nchisecapi-production.up.railway.app/bella/:path*" },
    { "source": "/api/:path*",     "destination": "https://nchisecapi-production.up.railway.app/:path*" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/login",          "destination": "/bella.html" },
    { "source": "/dashboard",      "destination": "/bella.html" },
    { "source": "/history",        "destination": "/bella.html" },
    { "source": "/users",          "destination": "/bella.html" }
  ]
}
